{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM"],
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["chrome", "bun"],
    "paths": {
      "@fairfox/polly": ["../../packages/polly/src/index.ts"],
      "@fairfox/polly/state": ["../../packages/polly/src/shared/lib/state.ts"],
      "@fairfox/polly/message-bus": ["../../packages/polly/src/shared/lib/message-bus.ts"],
      "@fairfox/polly/message-router": ["../../packages/polly/src/background/message-router.ts"],
      "@fairfox/polly/background": ["../../packages/polly/src/background/index.ts"],
      "@fairfox/polly/types": ["../../packages/polly/src/shared/types/messages.ts"],
      "@fairfox/polly/test": ["../../packages/polly/tools/test/src/index.ts"],
      "@fairfox/polly/verify": ["../../packages/polly/tools/verify/src/config.ts"],
      "@fairfox/polly/bdd": ["../../packages/polly/tools/bdd/src/index.ts"],
      "@/*": ["../../packages/polly/src/*"]
    }
  },
  "include": ["src/**/*", "tests/**/*", "specs/**/*", "features/**/*"]
}
